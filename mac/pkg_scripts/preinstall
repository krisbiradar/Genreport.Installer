#!/bin/bash
# mac/pkg_scripts/preinstall
#
# Runs as root BEFORE files are copied.
# Collects all user input via osascript dialogs, then writes values to
# /tmp/genreport_install_config for postinstall to consume.

set -e

# ── Helper: prompt for a single value ────────────────────────────────────────
ask() {
  local prompt="$1"
  local default="$2"
  local secret="$3"   # "true" = hidden (password) field

  if [ "$secret" = "true" ]; then
    osascript -e "
      set result to display dialog \"$prompt\" \
        default answer \"\" \
        with hidden answer \
        with title \"Genreport Setup\" \
        buttons {\"Continue\"} default button 1
      return text returned of result"
  else
    osascript -e "
      set result to display dialog \"$prompt\" \
        default answer \"$default\" \
        with title \"Genreport Setup\" \
        buttons {\"Continue\"} default button 1
      return text returned of result"
  fi
}

# ── Helper: section banner ────────────────────────────────────────────────────
banner() {
  osascript -e "
    display dialog \"$1\" \
      with title \"Genreport Setup\" \
      buttons {\"Continue\"} default button 1" > /dev/null
}

# ── Page 1: Database ──────────────────────────────────────────────────────────
banner "Step 1 of 4 — Database configuration\n\nEnter your PostgreSQL connection details."

DB_HOST=$(ask "Database host:" "localhost")
DB_PORT=$(ask "Database port:" "5432")
DB_NAME=$(ask "Database name:" "genreport")
DB_USER=$(ask "Database username:" "postgres")
DB_PASS=$(ask "Database password:" "" "true")

# ── Page 2: Application port ──────────────────────────────────────────────────
banner "Step 2 of 4 — Application port\n\nGenreport will be accessible at http://localhost:[port]\n\nAll internal services are managed automatically.\nChange the port only if 2905 is already in use."

APP_PORT=$(ask "Application port:" "2905")

# ── Page 3: SMTP ──────────────────────────────────────────────────────────────
banner "Step 3 of 4 — Email (SMTP)\n\nOutbound email settings. Leave blank to configure later."

SMTP_HOST=$(ask "SMTP host (leave blank to skip):" "")
SMTP_PORT=$(ask "SMTP port:" "587")
SMTP_USER=$(ask "SMTP username:" "")
SMTP_PASS=$(ask "SMTP password:" "" "true")
SMTP_FROM=$(ask "From address:" "noreply@genreport.app")

# ── Page 4: Cloudflare R2 ─────────────────────────────────────────────────────
banner "Step 4 of 4 — R2 Storage (Cloudflare)\n\nLeave blank to configure later."

R2_ACCOUNT=$(ask "R2 Account ID:" "")
R2_BUCKET=$(ask "R2 Bucket:" "")
R2_KEY=$(ask "R2 Access Key ID:" "")
R2_SECRET=$(ask "R2 Secret Key:" "" "true")
R2_URL=$(ask "R2 Public URL:" "")

# ── Write temp config for postinstall ─────────────────────────────────────────
cat > /tmp/genreport_install_config <<EOF
DB_HOST="$DB_HOST"
DB_PORT="$DB_PORT"
DB_NAME="$DB_NAME"
DB_USER="$DB_USER"
DB_PASS="$DB_PASS"
APP_PORT="$APP_PORT"
SMTP_HOST="$SMTP_HOST"
SMTP_PORT="$SMTP_PORT"
SMTP_USER="$SMTP_USER"
SMTP_PASS="$SMTP_PASS"
SMTP_FROM="$SMTP_FROM"
R2_ACCOUNT="$R2_ACCOUNT"
R2_BUCKET="$R2_BUCKET"
R2_KEY="$R2_KEY"
R2_SECRET="$R2_SECRET"
R2_URL="$R2_URL"
EOF

chmod 600 /tmp/genreport_install_config
exit 0
