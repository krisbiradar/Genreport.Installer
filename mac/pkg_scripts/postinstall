#!/bin/bash
# mac/pkg_scripts/postinstall
#
# Runs as root AFTER files are copied.
# Sources the temp config written by preinstall, calls the config writer binary,
# registers the launchd service, then removes the temp file (it contains secrets).

set -e
# shellcheck source=/dev/null
source /tmp/genreport_install_config

INSTALL_DIR="/Applications/Genreport"

# ── Run the config writer ─────────────────────────────────────────────────────
# Build the base args; security keys are added conditionally below.
CW_ARGS=(
  --installdir  "$INSTALL_DIR"
  --appport     "$APP_PORT"
  --dbhost      "$DB_HOST"
  --dbport      "$DB_PORT"
  --dbname      "$DB_NAME"
  --dbuser      "$DB_USER"
  --dbpassword  "$DB_PASS"
  --smtphost    "$SMTP_HOST"
  --smtpport    "$SMTP_PORT"
  --smtpuser    "$SMTP_USER"
  --smtppass    "$SMTP_PASS"
  --smtpfrom    "$SMTP_FROM"
  --r2accountid "$R2_ACCOUNT"
  --r2bucket    "$R2_BUCKET"
  --r2accesskey "$R2_KEY"
  --r2secretkey "$R2_SECRET"
  --r2publicurl "$R2_URL"
)

# Only pass custom security keys; omit flags to let configwriter auto-generate.
if [ -n "$JWT_SECRET" ] && [ "$JWT_SECRET" != "(auto-generate)" ]; then
  CW_ARGS+=(--jwtsecret "$JWT_SECRET")
fi
if [ -n "$ENCRYPTION_KEY" ] && [ "$ENCRYPTION_KEY" != "(auto-generate)" ]; then
  CW_ARGS+=(--encryptionkey "$ENCRYPTION_KEY")
fi

"$INSTALL_DIR/configwriter" "${CW_ARGS[@]}"

# ── Install and Configure Ollama ──────────────────────────────────────────────
if [ "$OLLAMA_INSTALL" = "yes" ]; then
  # Download and run the official macOS installation script quietly
  curl -fsSL https://ollama.com/install.sh | sh
fi

if [ "$OLLAMA_INSTALL" = "yes" ] || [ "$OLLAMA_INSTALL" = "already_installed" ]; then
  # Ensure the server is running to pull the model
  OLLAMA_PID=""
  if ! curl -s http://localhost:11434/ > /dev/null; then
    ollama serve >/dev/null 2>&1 &
    OLLAMA_PID=$!
    sleep 3  # Wait for server to bound port
  fi

  # Pull the small embedding model
  ollama pull nomic-embed-text

  # Stop the temporary server if we started it
  if [ -n "$OLLAMA_PID" ]; then
    kill $OLLAMA_PID
  fi
fi

# ── Register launchd service ──────────────────────────────────────────────────
cp "$INSTALL_DIR/com.genreport.launcher.plist" \
   /Library/LaunchDaemons/

launchctl load /Library/LaunchDaemons/com.genreport.launcher.plist

# ── Clean up (temp file contains passwords) ───────────────────────────────────
rm -f /tmp/genreport_install_config

exit 0
